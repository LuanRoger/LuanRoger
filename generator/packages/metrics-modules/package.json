{
  "name": "metrics-modules",
  "version": "0.0.0",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsdown --watch ./src",
    "build": "tsdown"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./modules": {
      "import": "./dist/modules/index.mjs",
      "types": "./dist/modules/index.d.ts",
      "default": "./dist/modules/index.js"
    }
  },
  "dependencies": {
    "takumi-js": "catalog:",
    "ky": "^2.0.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsdown": "^0.21.10"
  }
}
